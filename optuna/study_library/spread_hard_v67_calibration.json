{
  "notes": [
    "CPU-friendly calibration sweep for simple_spread_dynamic_hard with policy-reliance-gated PIMAC variants.",
    "Calibrates MAPPO, PIMAC v0, PIMAC v6, and PIMAC v7 only.",
    "Run with --parallel-jobs 3."
  ],
  "task": "simple_spread_dynamic_hard",
  "seed": 42,
  "task_overrides": {
    "episodes": 10000,
    "eval_every_episodes": 0,
    "test_rollouts": 30
  },
  "algorithms": [
    {
      "name": "mappo",
      "trials": 36,
      "base_config": "simple_spread_dynamic_hard/configs/mappo/default.json",
      "search": {
        "actor_arch": {
          "type": "categorical",
          "values": [
            { "num_hidden": 1, "widths": [64, 64] },
            { "num_hidden": 2, "widths": [64, 64, 64] },
            { "num_hidden": 2, "widths": [64, 128, 64] },
            { "num_hidden": 2, "widths": [128, 128, 128] },
            { "num_hidden": 2, "widths": [128, 256, 128] },
            { "num_hidden": 3, "widths": [96, 128, 128, 96] }
          ],
          "merge": true
        },
        "lr": {
          "type": "float",
          "low": 0.00003,
          "high": 0.002,
          "log": true
        },
        "batch_size": {
          "type": "categorical",
          "values": [32, 64, 128, 256]
        },
        "update_every_episodes": {
          "type": "categorical",
          "values": [1, 2, 4, 8, 16]
        },
        "num_epochs": {
          "type": "categorical",
          "values": [2, 4, 6, 8]
        },
        "rnn_hidden_dim": {
          "type": "categorical",
          "values": [32, 64, 128, 192]
        },
        "clip_eps": {
          "type": "categorical",
          "values": [0.1, 0.15, 0.2, 0.25, 0.3]
        },
        "gamma": {
          "type": "categorical",
          "values": [0.97, 0.985, 0.99, 0.995]
        },
        "gae_lambda": {
          "type": "categorical",
          "values": [0.9, 0.93, 0.95, 0.97, 0.99]
        },
        "entropy_coef": {
          "type": "float",
          "low": 0.0001,
          "high": 0.05,
          "log": true
        },
        "value_coef": {
          "type": "categorical",
          "values": [0.25, 0.5, 1.0, 2.0]
        },
        "max_grad_norm": {
          "type": "categorical",
          "values": [0.5, 1.0, 2.0, 5.0, 10.0]
        },
        "critic_hidden_sizes": {
          "type": "categorical",
          "values": [
            [64, 64],
            [96, 96],
            [128, 96],
            [128, 128],
            [160, 128],
            [160, 160],
            [128, 128, 128],
            [160, 160, 160]
          ]
        }
      }
    },
    {
      "name": "pimac_v0",
      "trials": 32,
      "base_config": "simple_spread_dynamic_hard/configs/pimac_v0/default.json",
      "inherit": [
        {
          "from": "mappo",
          "keys": [
            "lr",
            "batch_size",
            "update_every_episodes",
            "num_epochs",
            "num_hidden",
            "widths",
            "rnn_hidden_dim",
            "clip_eps",
            "gamma",
            "gae_lambda",
            "entropy_coef",
            "value_coef",
            "max_grad_norm"
          ],
          "required": true
        }
      ],
      "search": {
        "critic_hidden_sizes": {
          "type": "categorical",
          "values": [
            [64, 64],
            [96, 96],
            [128, 96],
            [128, 128],
            [160, 128],
            [160, 160],
            [128, 128, 128]
          ]
        },
        "set_embed_dim": {
          "type": "categorical",
          "values": [48, 64, 96, 128, 160]
        },
        "set_encoder_hidden_sizes": {
          "type": "categorical",
          "values": [
            [48, 48],
            [64, 64],
            [96, 64],
            [96, 96],
            [128, 64],
            [128, 128],
            [160, 96]
          ]
        },
        "include_team_size_feature": {
          "type": "categorical",
          "values": [false, true]
        }
      }
    },
    {
      "name": "pimac_v6",
      "trials": 72,
      "base_config": "simple_spread_dynamic_hard/configs/pimac_v6/default.json",
      "inherit": [
        {
          "from": "mappo",
          "keys": [
            "lr",
            "batch_size",
            "update_every_episodes",
            "num_epochs",
            "num_hidden",
            "widths",
            "rnn_hidden_dim",
            "clip_eps",
            "gamma",
            "gae_lambda",
            "entropy_coef",
            "value_coef",
            "max_grad_norm"
          ],
          "required": true
