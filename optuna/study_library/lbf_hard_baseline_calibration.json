{
  "notes": [
    "Baseline-only hard-task calibration sweep for lbf_hard.",
    "Tunes IPPO, IQL, VDN, and QMIX independently with the same per-trial task structure as the ongoing hard PIMAC sweeps.",
    "No chaining between algorithms.",
    "Run with --parallel-jobs 4."
  ],
  "task": "lbf_hard",
  "seed": 42,
  "task_overrides": {
    "episodes": 6000,
    "eval_every_episodes": 0,
    "test_rollouts": 30
  },
  "algorithms": [
    {
      "name": "ippo",
      "trials": 36,
      "base_config": "lbf_hard/configs/ippo/default.json",
      "search": {
        "actor_arch": {
          "type": "categorical",
          "values": [
            { "num_hidden": 1, "widths": [64, 64] },
            { "num_hidden": 2, "widths": [64, 128, 64] },
            { "num_hidden": 2, "widths": [128, 128, 128] },
            { "num_hidden": 2, "widths": [128, 256, 128] },
            { "num_hidden": 3, "widths": [96, 128, 128, 96] }
          ],
          "merge": true
        },
        "lr": {
          "type": "float",
          "low": 0.00005,
          "high": 0.0015,
          "log": true
        },
        "batch_size": {
          "type": "categorical",
          "values": [64, 128, 256]
        },
        "update_every_episodes": {
          "type": "categorical",
          "values": [2, 4, 8, 16]
        },
        "num_epochs": {
          "type": "categorical",
          "values": [2, 4, 6, 8]
        },
        "rnn_hidden_dim": {
          "type": "categorical",
          "values": [64, 128, 192]
        },
        "clip_eps": {
          "type": "categorical",
          "values": [0.1, 0.15, 0.2, 0.25, 0.3]
        },
        "gamma": {
          "type": "categorical",
          "values": [0.97, 0.985, 0.99]
        },
        "gae_lambda": {
          "type": "categorical",
          "values": [0.9, 0.93, 0.95, 0.97, 0.99]
        },
        "entropy_coef": {
          "type": "float",
          "low": 0.0001,
          "high": 0.02,
          "log": true
        },
        "value_coef": {
          "type": "categorical",
          "values": [0.25, 0.5, 1.0, 2.0]
        },
        "max_grad_norm": {
          "type": "categorical",
          "values": [0.5, 1.0, 2.0, 5.0]
        }
      }
    },
    {
      "name": "iql",
      "trials": 36,
      "base_config": "lbf_hard/configs/iql/default.json",
      "search": {
        "q_arch": {
