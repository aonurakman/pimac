          "type": "categorical",
          "values": [0.05, 0.1, 0.25, 0.5, 1.0]
        },
        "temp_init": {
          "type": "categorical",
          "values": [1.0, 1.5, 2.0]
        },
        "temp_min": {
          "type": "categorical",
          "values": [0.05, 0.1, 0.2]
